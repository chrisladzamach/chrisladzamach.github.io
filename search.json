---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "formatted_date": {{ post.date | date: "%d %b %Y" | jsonify }},
    "category": {{ post.categories | first | jsonify }},
    "description": {{ post.description | default: post.excerpt | strip_html | truncate: 200 | jsonify }},
    "image": {{ post.image | relative_url | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "content": {{ post.content | strip_html | truncate: 1200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
